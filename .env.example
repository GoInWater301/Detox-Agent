# ==============================
# Detox-Agent Docker Environment
# ==============================

# PostgreSQL
POSTGRES_DB=detox_analytics
POSTGRES_USER=detox
POSTGRES_PASSWORD=detox
POSTGRES_HOST_PORT=5432

# Redis (container-to-container)
REDIS_HOST=redis
REDIS_PORT=6379

# WebServer
WEBSERVER_HOST_PORT=8080
AI_AGENT_GRPC_HOST=agent
AI_AGENT_GRPC_PORT=50051
AI_AGENT_GRPC_USE_PLAINTEXT=true

# Agent
AGENT_HOST_PORT=8000
USAGE_GRPC_HOST=webserver
USAGE_GRPC_PORT=9090
OPENAI_API_KEY=

# Frontend
FRONTEND_HOST_PORT=3000
