# DoH Beast Forwarder — 설정 파일 예시
# 이 파일을 .env 로 복사하고 값을 수정하세요.
#
# 우선순위: 프로세스 환경변수 > .env 파일 항목
# 다른 .env 파일을 사용하려면: DOH_ENV_FILE=/path/to/.env.prod ./doh-forwarder

# ─── 네트워크 ─────────────────────────────────────────────────────────────────
DOH_LISTEN_ADDR=0.0.0.0
DOH_LISTEN_PORT=443

# ─── TLS (Let's Encrypt) ──────────────────────────────────────────────────────
DOH_CERT_CHAIN=certs/fullchain.pem
DOH_PRIVATE_KEY=certs/privkey.pem

# ─── DNS 업스트림 ─────────────────────────────────────────────────────────────
DOH_DNS_UPSTREAM=8.8.8.8
DOH_DNS_PORT=53

# UDP 응답 대기 타임아웃 (밀리초). 초과 시 TCP 재시도.
DOH_DNS_TIMEOUT_MS=3000

# TTL 강제 범위 (초) — 사용자 모니터링 목적
# 업스트림 TTL이 이 범위를 벗어나면 강제 조정됩니다.
# 짧은 TTL = 클라이언트가 자주 재질의 = 더 많은 모니터링 데이터
# RFC 8484 권장: max-age는 DNS 응답 TTL 기준이나, 여기서 오버라이드합니다.
DOH_DNS_MIN_TTL=30    # 30초 이하 TTL → 30초로 올림
DOH_DNS_MAX_TTL=60    # 60초 초과 TTL → 60초로 내림

# ─── 도메인 필터 (Redis) ─────────────────────────────────────────────────────
# "true" 로 설정 시 Redis 기반 차단 필터 활성화
DOH_FILTER_ENABLED=false

DOH_REDIS_HOST=127.0.0.1
DOH_REDIS_PORT=6379
DOH_REDIS_PASSWORD=             # 없으면 빈 문자열

# ─── 분석 서버 (gRPC) ────────────────────────────────────────────────────────
DOH_ANALYTICS_EP=localhost:50051

# 인메모리 이벤트 큐 최대 크기. 초과 시 가장 오래된 이벤트 드롭.
DOH_ANALYTICS_CAP=4096
